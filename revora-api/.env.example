# ─────────────────────────────────────────────
# REVORA API — Environment Variables
# Copy this file to .env and fill in real values
# NEVER commit .env to git
# ─────────────────────────────────────────────

# ── App ──────────────────────────────────────
NODE_ENV=production
PORT=3000
API_VERSION=v1

# ── Database (Railway PostgreSQL) ────────────
# From Railway dashboard → PostgreSQL service → Connect tab
DATABASE_URL=postgresql://postgres:PASSWORD@HOST:PORT/railway
# Prisma Accelerate URL (get from prisma.io/accelerate after linking your DB)
# DATABASE_URL=prisma://accelerate.prisma-data.net/?api_key=YOUR_KEY
# Required when using Prisma Accelerate (used for migrations only)
DIRECT_URL=postgresql://postgres:PASSWORD@HOST:PORT/railway

# ── Redis (Railway Redis) ─────────────────────
# From Railway dashboard → Redis service → Connect tab
REDIS_URL=redis://:PASSWORD@HOST:PORT

# ── Auth / JWT ───────────────────────────────
JWT_ACCESS_SECRET=GENERATE_WITH__openssl rand -hex 32
JWT_REFRESH_SECRET=GENERATE_DIFFERENT__openssl rand -hex 32
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ── Google OAuth ─────────────────────────────
# Create at console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=https://YOUR_RAILWAY_API_URL/api/v1/auth/google/callback

# ── Razorpay ─────────────────────────────────
# Get from dashboard.razorpay.com → Settings → API Keys
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXX
RAZORPAY_KEY_SECRET=your_razorpay_secret
# Set at: dashboard.razorpay.com → Settings → Webhooks
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# ── Cloudinary ───────────────────────────────
# Get from cloudinary.com → Dashboard
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Meilisearch Cloud ────────────────────────
# Get from cloud.meilisearch.com
MEILISEARCH_HOST=https://ms-XXXX.sfo.meilisearch.io
MEILISEARCH_API_KEY=your_meilisearch_key

# ── OpenAI ───────────────────────────────────
# Get from platform.openai.com → API Keys
OPENAI_API_KEY=sk-proj-XXXXXXXXXX

# ── Email (Resend) ───────────────────────────
# Get from resend.com → API Keys
RESEND_API_KEY=re_XXXXXXXXXX
RESEND_FROM_EMAIL=noreply@revora.com

# ── SMS (Twilio) ─────────────────────────────
# Get from console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE=+1XXXXXXXXXX

# ── Monitoring (Sentry) ──────────────────────
# Get from sentry.io → Project Settings → DSN
SENTRY_DSN=https://XXXX@oXXXX.ingest.sentry.io/XXXX

# ── CORS ─────────────────────────────────────
# The URL of your deployed frontend
FRONTEND_URL=https://revora.vercel.app
ADMIN_URL=https://admin.revora.com
