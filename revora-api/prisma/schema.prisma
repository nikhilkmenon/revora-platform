// Prisma schema for REVORA Luxury Marketplace
// Railway PostgreSQL

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [vector]
}

// ── Roles ─────────────────────────────────────────────────────────────
enum Role {
  BUYER
  DESIGNER
  SUPPLIER
  ADMIN
  SUPER_ADMIN
}

enum KycStatus {
  PENDING
  SUBMITTED
  APPROVED
  REJECTED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  SHIPPED
  DELIVERED
  RETURNED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  CAPTURED
  FAILED
  REFUNDED
}

enum ProductStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
}

// ── Users ─────────────────────────────────────────────────────────────
model User {
  id            String    @id @default(uuid())
  email         String    @unique
  phone         String?   @unique
  passwordHash  String?
  name          String
  avatar        String?
  role          Role      @default(BUYER)
  googleId      String?   @unique
  oauthCode     String?   @unique
  oauthCodeExpiresAt DateTime?
  refreshToken  String?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  orders        Order[]
  designer      Designer?
  supplier      Supplier?
  activityLogs  ActivityLog[]
  auditLogs     AuditLog[]
  notifications Notification[]

  @@index([email])
  @@index([role])
}

// ── Designers ─────────────────────────────────────────────────────────
model Designer {
  id          String    @id @default(uuid())
  userId      String    @unique
  user        User      @relation(fields: [userId], references: [id])
  brandName   String
  bio         String?
  bannerImage String?
  socialLinks Json?
  kycStatus   KycStatus @default(PENDING)
  gstNumber   String?
  panNumber   String?
  portfolioUrl String?
  isApproved  Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  products    Product[]
  kyc         KycVerification?
  payouts     Payout[]
}

// ── Suppliers ─────────────────────────────────────────────────────────
model Supplier {
  id          String   @id @default(uuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id])
  companyName String
  gstNumber   String?
  isApproved  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  fabrics     Fabric[]
}

// ── Products ──────────────────────────────────────────────────────────
model Product {
  id          String        @id @default(uuid())
  name        String
  description String
  price       Decimal       @db.Decimal(12,2)
  compareAt   Decimal?      @db.Decimal(12,2)
  sku         String        @unique
  stock       Int           @default(0)
  images      String[]
  tags        String[]
  aiTags      String[]
  category    String
  status      ProductStatus @default(DRAFT)
  designerId  String
  designer    Designer      @relation(fields: [designerId], references: [id])
  embedding   Unsupported("vector(1536)")? // Vector stored as JSON for pgvector queries
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  orderItems  OrderItem[]

  @@index([status])
  @@index([category])
  @@index([designerId])
}

// ── Fabrics ───────────────────────────────────────────────────────────
model Fabric {
  id          String   @id @default(uuid())
  name        String
  description String
  pricePerYard Decimal @db.Decimal(12,2)
  moq         Int
  stock       Int
  images      String[]
  category    String
  supplierId  String
  supplier    Supplier @relation(fields: [supplierId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  orderItems  OrderItem[]
}

// ── Orders ────────────────────────────────────────────────────────────
model Order {
  id              String      @id @default(uuid())
  idempotencyKey  String?     @unique
  razorpayOrderId String?     @unique
  userId          String
  user            User        @relation(fields: [userId], references: [id])
  status          OrderStatus @default(PENDING)
  total           Decimal @db.Decimal(12,2)
  address         Json
  expiresAt       DateTime?   // For order expiry logic
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  items       OrderItem[]
  payment     Payment?
  payouts     Payout[]
  tracking    OrderTracking[]

  @@index([userId])
  @@index([status])
}

model OrderItem {
  id        String  @id @default(uuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id])
  productId String?
  product   Product? @relation(fields: [productId], references: [id])
  fabricId  String?
  fabric    Fabric?  @relation(fields: [fabricId], references: [id])
  quantity  Int
  price     Decimal @db.Decimal(12,2)
}

model OrderTracking {
  id        String   @id @default(uuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id])
  status    String
  message   String
  createdAt DateTime @default(now())
}

// ── Payments ──────────────────────────────────────────────────────────
model Payment {
  id              String        @id @default(uuid())
  orderId         String        @unique
  order           Order         @relation(fields: [orderId], references: [id])
  razorpayPayId   String?       @unique
  amount          Decimal @db.Decimal(12,2)
  currency        String        @default("INR")
  status          PaymentStatus @default(PENDING)
  webhookVerified Boolean       @default(false)
  eventId         String?       @unique       // For replay attack prevention
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

// ── Payouts (Escrow System) ──────────────────────────────────────────
model Payout {
  id          String   @id @default(uuid())
  designerId  String
  designer    Designer @relation(fields: [designerId], references: [id])
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id])
  amount      Decimal @db.Decimal(12,2)
  status      String   @default("PENDING") // PENDING, PROCESSING, COMPLETED
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([orderId])
}

// ── KYC ───────────────────────────────────────────────────────────────
model KycVerification {
  id          String    @id @default(uuid())
  designerId  String    @unique
  designer    Designer  @relation(fields: [designerId], references: [id])
  gstDoc      String?
  panDoc      String?
  portfolio   String?
  status      KycStatus @default(PENDING)
  reviewNotes String?
  reviewedAt  DateTime?
  createdAt   DateTime  @default(now())
}

// ── Notifications ─────────────────────────────────────────────────────
model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  title     String
  body      String
  type      String?  // e.g. "ORDER_UPDATE", "PROMO"
  data      Json?    // Optional structured metadata
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
}

// ── Audit & Activity Logs ─────────────────────────────────────────────
model ActivityLog {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  action    String
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([entity, entityId])
  @@index([createdAt])
}
